# PostgreSQL connection URL.
# "db" is the service name in docker-compose — Docker automatically
# resolves this name to the container's internal IP address.
DATABASE_URL=postgresql+asyncpg://moodqueue:moodqueue@db:5432/moodqueue

# Same logic for Redis — "redis" resolves to the Redis container
REDIS_URL=redis://redis:6379

# Generate a real random key later with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_secret_key

# These keys will be set up in steps 5 and 6
OPENAI_API_KEY=sk-placeholder
SPOTIFY_CLIENT_ID=placeholder
SPOTIFY_CLIENT_SECRET=placeholder